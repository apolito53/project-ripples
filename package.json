{
  "name": "ripple-field-lab",
  "version": "0.3.12-ALPHA",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5183 --strictPort",
    "debug:logs": "node scripts/debug-log-server.mjs",
    "diagnostics": "node scripts/analyze-debug-log.mjs",
    "logs:summary": "node scripts/analyze-debug-log.mjs",
    "verify:perf": "node scripts/analyze-debug-log.mjs --max-frame-ms=1500 --max-rebuild-ms=1500 --max-update-ms=120 --max-render-ms=1500",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4183 --strictPort",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "three": "^0.175.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.16"
  }
}
